ENV=dev

# Database
POSTGRES_URL=postgresql+asyncpg://agentforge:agentforge@postgres:5432/agentforge

# Vector store
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agentforge

# LLM (set provider + key to use a real model; defaults to mock)
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-6
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS Bedrock (LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
# Standard AWS credent