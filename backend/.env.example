ENV=dev

# Database
POSTGRES_URL=postgresql+asyncpg://agentforge:agentforge@postgres:5432/agentforge

# Vector store
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agentforge

# LLM (set provider + key to use a real model; defaults to mock)
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-6
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
